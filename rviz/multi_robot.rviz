Panels:
  - Class: rviz/Displays
    Help Height: 138
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /RobotModel [Red]1
        - /RobotModel [Red2]1
        - /RobotModel [Blue]1
        - /RobotModel [Blue2]1
        - /LaserScan [Red]1
        - /LaserScan [Red2]1
        - /LaserScan [Blue]1
        - /LaserScan [Blue2]1
        - /Map1
        - /Global Map [Red]1/Costmap1
        - /Global Map [Red]1/Planner1
        - /Global Map [Red2]1/Costmap1
        - /Global Map [Red2]1/Planner1
        - /Local Map [Red]1/Costmap1
        - /Local Map [Red]1/Planner1
        - /Local Map [Red2]1/Costmap1
        - /Local Map [Red2]1/Planner1
        - /Global Map [Blue]1/Costmap1
        - /Global Map [Blue]1/Planner1
        - /Global Map [Blue2]1/Costmap1
        - /Global Map [Blue2]1/Planner1
        - /Local Map [Blue]1/Costmap1
        - /Local Map [Blue]1/Planner1
        - /Local Map [Blue2]1/Costmap1
        - /Local Map [Blue2]1/Planner1
        - /Goal [Red]1
        - /Goal [Red2]1
        - /Goal [Blue]1
        - /Goal [Blue2]1
      Splitter Ratio: 0.5
    Tree Height: 757
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded: ~
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: LaserScan [Red]
